# ─────────────────────────────────────────
# Minecraft Bot — Environment Variables
# Copy this to .env (for local) or paste in Render dashboard
# ─────────────────────────────────────────

# 🎮 Minecraft Server
MC_HOST=your-minecraft-server-ip-or-domain
MC_PORT=25565
MC_USERNAME=KeepAliveBot
MC_VERSION=1.20.1

# Auth mode: "offline" (cracked) or "microsoft" (premium)
MC_AUTH=offline

# 🌐 Render Self-Pinger
# Paste your Render app URL here (e.g. https://my-mc-bot.onrender.com)
RENDER_URL=https://your-app-name.onrender.com

# How often to self-ping in milliseconds (default: 5 minutes)
PING_INTERVAL_MS=300000

# 🔌 Reconnect delay in milliseconds (default: 5s, scales up per attempt)
RECONNECT_DELAY_MS=5000

# 🤸 Anti-AFK interval in milliseconds (default: 30s)
AFK_INTERVAL_MS=30000

# 📋 Express server port (Render sets this automatically, don't change)
PORT=3000
